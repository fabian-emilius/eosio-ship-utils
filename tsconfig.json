{
    "ts-node": {
        "files": true,
        "esm": true
    },
    "compilerOptions": {
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "noImplicitAny": true,
        "target": "ES2022",
        "rootDir": "src",
        "outDir": "build",
        "declaration": true,
        "sourceMap": true,
        "esModuleInterop": true,
        "resolveJsonModule": true,
        "experimentalDecorators": true
    },
    "include": ["src/**/*.ts"],
    "exclude": ["docs", "test", "node_modules", "**/*.test.ts"]
}
