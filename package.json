{
  "name": "spring-ship-tools",
  "version": "1.0.0",
  "description": "TypeScript utilities for connecting to and consuming EOSIO/Antelope State History (Ship) WebSocket endpoints",
  "author": "Fabian Emilius",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/fabian-emilius/spring-ship-tools.git"
  },
  "homepage": "https://github.com/fabian-emilius/spring-ship-tools#readme",
  "bugs": {
    "url": "https://github.com/fabian-emilius/spring-ship-tools/issues"
  },
  "keywords": [
    "eosio",
    "antelope",
    "spring",
    "ship",
    "state-history"
  ],
  "engines": {
    "node": ">=22.0.0"
  },
  "type": "module",
  "main": "build/index.js",
  "types": "build/index.d.ts",
  "files": [
    "build",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "start:example": "tsc && node build/bin/base-example.js",
    "dev:start:example": "DEV=true nodemon src/bin/base-example.ts",
    "lint": "eslint 'src/**/*.ts'",
    "prepare": "husky"
  },
  "dependencies": {
    "common-tags": "^1.8.2",
    "eosjs": "^22.1.0",
    "node-worker-threads-pool": "^1.5.1",
    "p-queue": "^9.1.2",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/common-tags": "^1.8.4",
    "@types/elliptic": "^6.4.18",
    "@types/node": "^22.0.0",
    "@types/ws": "^8.5.13",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.0",
    "lint-staged": "^16.4.0",
    "nodemon": "^3.1.0",
    "nyc": "^18.0.0",
    "prettier": "^3.4.0",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  },
  "lint-staged": {
    "*.{ts,js}": [
      "prettier --config .prettierrc.json --write",
      "eslint --fix"
    ]
  }
}
